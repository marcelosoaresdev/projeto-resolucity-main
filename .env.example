# Environment variables - DO NOT COMMIT actual values
# Copy this to .env and fill in real values

PORT=3000
SESSION_SECRET=your-secret-here
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# Email configuration (Nodemailer)
# SMTP host (e.g., smtp.gmail.com, smtp.seudominio.com.br)
# EMAIL_HOST=smtp.example.com

# SMTP port (587 for TLS, 465 for SSL, 25 for plain)
# EMAIL_PORT=587

# Use TLS/SSL (true for port 465, false for 587)
# EMAIL_SECURE=false

# SMTP authentication username
# EMAIL_USER=noreply@example.com.br

# SMTP authentication password
# EMAIL_PASS=your_password_here

# From address for emails
# EMAIL_FROM="Resolucity <noreply@example.com.br>"

# Base URL for generating confirmation links
# BASE_URL=http://localhost:3000